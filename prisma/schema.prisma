// Prisma schema for Pokemon Palette.
//
// The app uses Supabase for the storage layer but Prisma as the primary
// ORM for all table queries. The only callers of the supabase client are
// the six SECURITY DEFINER RPCs (admin analytics + stats) where an RPC
// trip is genuinely simpler than the same SQL in Prisma.
//
// Models mirror the SQL migrations under `supabase/migrations/`. Keep the
// following invariants when editing:
//   - PKs, columns, defaults, and `@map` names must match the live table.
//   - `@db.Timestamptz(6)` matches `TIMESTAMPTZ` + microsecond precision.
//   - Indexes declared with `@@index(..., map: "...")` must use the same
//     name as the CREATE INDEX in the migration, so Prisma does not try
//     to re-create them on `prisma migrate deploy`.
//
// Migration strategy: we continue to own the schema via raw SQL files in
// supabase/migrations (they also encode RLS policies and RPCs that
// Prisma cannot express). Prisma is used only for typed queries, NOT for
// migrations. This is the officially supported "introspection-only" mode.

generator client {
  provider = "prisma-client-js"
  // Generating into the default node_modules location; the previous
  // output in src/generated/prisma is not needed and was gitignored.
}

datasource db {
  provider  = "postgresql"
  // Runtime url — use the Supabase pgbouncer pooler (port 6543,
  // transaction mode) on serverless deployments to avoid connection
  // exhaustion. See .env.example / docs for the exact URL.
  url       = env("DATABASE_URL")
  // Direct url — only used by `prisma migrate` / `db push`. Not used at
  // runtime.
  directUrl = env("DIRECT_URL")
}

model User {
  id                         String    @id
  email                      String?
  firstName                  String?   @map("first_name")
  lastName                   String?   @map("last_name")
  username                   String?
  imageUrl                   String?   @map("image_url")
  profileImageUrl            String?   @map("profile_image_url")
  hasImage                   Boolean   @default(false) @map("has_image")
  primaryEmailAddressId      String?   @map("primary_email_address_id")
  primaryPhoneNumberId       String?   @map("primary_phone_number_id")
  banned                     Boolean   @default(false)
  locked                     Boolean   @default(false)
  backupCodeEnabled          Boolean   @default(false) @map("backup_code_enabled")
  twoFactorEnabled           Boolean   @default(false) @map("two_factor_enabled")
  totpEnabled                Boolean   @default(false) @map("totp_enabled")
  passwordEnabled            Boolean   @default(false) @map("password_enabled")
  createOrganizationEnabled  Boolean   @default(true)  @map("create_organization_enabled")
  deleteSelfEnabled          Boolean   @default(true)  @map("delete_self_enabled")
  lastActiveAt               DateTime? @map("last_active_at") @db.Timestamptz(6)
  lastSignInAt               DateTime? @map("last_sign_in_at") @db.Timestamptz(6)
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDeleted                  Boolean   @default(false) @map("is_deleted")
  isAdmin                    Boolean   @default(false) @map("is_admin")
  receivesDailyEmails        Boolean   @default(true)  @map("receives_daily_emails")
  paletteSize                Int       @default(3)     @map("palette_size")
  countryCode                String?   @map("country_code")
  timezone                   String?
  geoUpdatedAt               DateTime? @map("geo_updated_at") @db.Timestamptz(6)
  emailAddresses             Json      @default("[]") @map("email_addresses")   @db.JsonB
  phoneNumbers               Json      @default("[]") @map("phone_numbers")     @db.JsonB
  externalAccounts           Json      @default("[]") @map("external_accounts") @db.JsonB
  publicMetadata             Json      @default("{}") @map("public_metadata")   @db.JsonB
  privateMetadata            Json      @default("{}") @map("private_metadata")  @db.JsonB
  unsafeMetadata             Json      @default("{}") @map("unsafe_metadata")   @db.JsonB
  savedPalettes        SavedPalette[]
  dailyGameAttempts    DailyGameAttempt[]
  dailyOverrides       DailyOverride[]
  emails               Email[]
  hostedRooms          MultiplayerRoom[]   @relation("RoomHost")
  wonRooms             MultiplayerRoom[]   @relation("RoomWinner")
  multiplayerPlayers   MultiplayerPlayer[]

  // Indexes declared in migrations 001 + 010.
  @@index([email],                  map: "idx_users_email")
  @@index([createdAt],               map: "idx_users_created_at")
  @@index([isDeleted],               map: "idx_users_is_deleted")
  @@index([primaryEmailAddressId],   map: "idx_users_primary_email_address_id")
  @@index([lastActiveAt],            map: "idx_users_last_active_at")
  @@index([banned],                  map: "idx_users_banned")
  @@index([locked],                  map: "idx_users_locked")
  @@index([countryCode],             map: "idx_users_country_code")
  @@map("users")
}

model SavedPalette {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id")
  pokemonId   Int      @map("pokemon_id")
  pokemonName String   @map("pokemon_name")
  pokemonForm String?  @map("pokemon_form")
  isShiny     Boolean  @default(false) @map("is_shiny")
  colors      Json     @db.JsonB
  imageUrl    String?  @map("image_url")
  paletteName String?  @map("palette_name")
  createdAt   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId],      map: "idx_saved_palettes_user_id")
  @@index([pokemonId],   map: "idx_saved_palettes_pokemon_id")
  @@index([createdAt],   map: "idx_saved_palettes_created_at")
  @@index([pokemonName], map: "idx_saved_palettes_pokemon_name")
  @@map("saved_palettes")
}

model DailyGameAttempt {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id")
  date            DateTime @db.Date
  targetPokemonId Int      @map("target_pokemon_id")
  isShiny         Boolean  @default(false) @map("is_shiny")
  guesses         Json     @db.JsonB
  attempts        Int
  won             Boolean  @default(false)
  pokemonGuessed  Int?     @map("pokemon_guessed")
  hintsUsed       Int      @default(0) @map("hints_used")
  createdAt       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Unique + indexes match migrations 003 / 009 / 010 / 016.
  @@unique([userId, date])
  @@index([userId, date(sort: Desc)], map: "idx_daily_game_attempts_user_date_desc")
  @@index([userId, createdAt(sort: Desc)], map: "idx_dga_user_created_at_desc")
  @@index([createdAt(sort: Desc)], map: "idx_dga_created_at_desc")
  @@index([targetPokemonId], map: "idx_dga_target_pokemon_id")
  @@map("daily_game_attempts")
}

model DailyOverride {
  date        DateTime @id @db.Date
  pokemonId   Int      @map("pokemon_id")
  isShiny     Boolean  @default(false) @map("is_shiny")
  createdBy   String   @map("created_by")
  note        String?
  createdAt   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("updated_at") @db.Timestamptz(6)

  creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([date],      map: "idx_daily_overrides_date")
  @@index([createdBy], map: "idx_daily_overrides_created_by")
  @@map("daily_overrides")
}

model Email {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resendId       String?  @unique @map("resend_id")
  userId         String?  @map("user_id")
  recipientEmail String   @map("recipient_email")
  senderEmail    String   @map("sender_email")
  senderName     String?  @map("sender_name")
  subject        String
  templateType   String   @map("template_type")
  htmlContent    String?  @map("html_content") @db.Text
  textContent    String?  @map("text_content") @db.Text
  status         String
  errorMessage   String?  @map("error_message") @db.Text
  sentAt         DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("sent_at")    @db.Timestamptz(6)
  createdAt      DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(dbgenerated("timezone('utc'::text, now())")) @updatedAt         @map("updated_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId],         map: "idx_emails_user_id")
  @@index([recipientEmail], map: "idx_emails_recipient_email")
  @@index([resendId],       map: "idx_emails_resend_id")
  @@index([templateType],   map: "idx_emails_template_type")
  @@index([status],         map: "idx_emails_status")
  @@index([sentAt],         map: "idx_emails_sent_at")
  @@index([createdAt],      map: "idx_emails_created_at")
  @@map("emails")
}

model MultiplayerRoom {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomCode        String    @unique @map("room_code") @db.VarChar(6)
  hostUserId      String    @map("host_user_id")
  targetPokemonId Int       @map("target_pokemon_id")
  isShiny         Boolean   @default(false) @map("is_shiny")
  status          String    @default("waiting") @db.VarChar(20)
  winnerUserId    String?   @map("winner_user_id")
  createdAt       DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)
  startedAt       DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz(6)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)

  host    User  @relation("RoomHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  winner  User? @relation("RoomWinner", fields: [winnerUserId], references: [id], onDelete: SetNull)
  players MultiplayerPlayer[]

  @@index([roomCode],    map: "idx_mp_rooms_room_code")
  @@index([hostUserId],  map: "idx_mp_rooms_host_user_id")
  @@index([status],      map: "idx_mp_rooms_status")
  @@index([expiresAt],   map: "idx_mp_rooms_expires_at")
  @@map("multiplayer_rooms")
}

model MultiplayerPlayer {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId         String    @map("room_id") @db.Uuid
  userId         String    @map("user_id")
  username       String?
  imageUrl       String?   @map("image_url")
  guesses        Json      @default("[]") @db.JsonB
  attempts       Int       @default(0)
  won            Boolean   @default(false)
  bestSimilarity Float     @default(0) @map("best_similarity")
  hintsUsed      Int       @default(0) @map("hints_used")
  finishedAt     DateTime? @map("finished_at") @db.Timestamptz(6)
  joinedAt       DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @map("joined_at") @db.Timestamptz(6)

  room MultiplayerRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId], map: "idx_mp_players_room_id")
  @@index([userId], map: "idx_mp_players_user_id")
  @@map("multiplayer_players")
}
